---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OptimizedImage from '../../components/OptimizedImage.astro';
import { getCollection } from 'astro:content';
import { formatBlogDate } from '../../utils/blog';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

const title = 'HODA Wellness Blog — Functional Medicine & Healthy Living';
const description =
  'Evidence-informed articles on metabolic health, functional medicine, nutrition, movement, and nervous system regulation from the HODA Wellness Group team.';
---

<BaseLayout title={title} description={description} ogImage="/images/why-hoda.jpg" activeNav="blog">
  <section class="page-intro">
    <div class="container">
      <span class="eyebrow">Resources</span>
      <h1>Insights for Stronger, Longer Living</h1>
      <p>
        Evidence-informed articles on metabolic health, nutrition, movement, and nervous
        system regulation — practical guidance from the HODA team.
      </p>
    </div>
  </section>

  <section class="section section--bg blog-index">
    <div class="container">
      {
        posts.length === 0 ? (
          <p class="blog-empty">No posts yet. Check back soon.</p>
        ) : (
          <div class="blog-grid">
            {posts.map((post) => (
              <article class="blog-card">
                <a class="blog-card__media" href={`/blog/${post.id}`}>
                  {post.data.heroImage ? (
                    <OptimizedImage
                      src={post.data.heroImage}
                      alt=""
                      width={640}
                      height={360}
                    />
                  ) : (
                    <div class="blog-card__placeholder" aria-hidden="true" />
                  )}
                </a>
                <div class="blog-card__body">
                  <time class="blog-card__date" datetime={post.data.publishDate.toISOString()}>
                    {formatBlogDate(post.data.publishDate)}
                  </time>
                  <h2 class="blog-card__title">
                    <a href={`/blog/${post.id}`}>{post.data.title}</a>
                  </h2>
                  <p class="blog-card__excerpt">{post.data.description}</p>
                  <a class="blog-card__link" href={`/blog/${post.id}`}>
                    Read article →
                  </a>
                </div>
              </article>
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
