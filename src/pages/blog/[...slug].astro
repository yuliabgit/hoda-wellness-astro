---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OptimizedImage from '../../components/OptimizedImage.astro';
import { getCollection, render } from 'astro:content';
import {
  estimateReadingTime,
  formatBlogDate,
  pickRelatedPosts,
} from '../../utils/blog';
import { absoluteUrl, getSiteUrl } from '../../utils/seo';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = pickRelatedPosts(allPosts, post.id);
const readingTime = estimateReadingTime(post.body ?? '');

const site = getSiteUrl(Astro.site);
const canonicalUrl = absoluteUrl(`/blog/${post.id}`, site);
const title = `${post.data.title} | HODA Wellness Group`;
const ogImage = post.data.heroImage ?? '/og-default.jpg';

const blogPostingSchema = {
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishDate.toISOString(),
  dateModified: post.data.publishDate.toISOString(),
  author: {
    '@type': 'Organization',
    name: post.data.author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'HODA Wellness Group',
    url: site.href,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
  image: [absoluteUrl(ogImage, site)],
  ...(post.data.tags?.length && { keywords: post.data.tags.join(', ') }),
};
---

<BaseLayout
  title={title}
  description={post.data.description}
  ogImage={ogImage}
  canonical={canonicalUrl}
  ogType="article"
  activeNav="blog"
  structuredData={blogPostingSchema}
>
  <article class="blog-post">
    <header class="blog-post__header">
      <div class="container blog-post__header-inner">
        <div class="breadcrumb blog-post__breadcrumb">
          <a href="/blog">Blog</a> / {post.data.title}
        </div>
        <h1>{post.data.title}</h1>
        <div class="blog-post__meta">
          <time datetime={post.data.publishDate.toISOString()}>
            {formatBlogDate(post.data.publishDate)}
          </time>
          <span class="blog-post__meta-sep" aria-hidden="true">·</span>
          <span>{post.data.author}</span>
          <span class="blog-post__meta-sep" aria-hidden="true">·</span>
          <span>{readingTime} min read</span>
        </div>
      </div>
      {
        post.data.heroImage && (
          <div class="blog-post__hero">
            <OptimizedImage
              src={post.data.heroImage}
              alt=""
              width={1200}
              height={525}
            />
          </div>
        )
      }
    </header>

    <div class="container">
      <div class="blog-prose">
        <Content />
      </div>

      {
        post.data.tags && post.data.tags.length > 0 && (
          <ul class="blog-tags">
            {post.data.tags.map((tag) => (
              <li>{tag}</li>
            ))}
          </ul>
        )
      }
    </div>

    {
      relatedPosts.length > 0 && (
        <section class="blog-related section section--bg-alt">
          <div class="container">
            <h2>Related posts</h2>
            <div class="blog-related__grid">
              {relatedPosts.map((related) => (
                <article class="blog-related__card">
                  <h3>
                    <a href={`/blog/${related.id}`}>{related.data.title}</a>
                  </h3>
                  <p>{related.data.description}</p>
                  <a class="blog-related__link" href={`/blog/${related.id}`}>
                    Read more →
                  </a>
                </article>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <section class="cta-banner">
      <h2>Ready to Take the Next Step?</h2>
      <p>Your best health is within reach. Let's build your personalized plan.</p>
      <a class="btn btn--warm" href="/contact">Contact Us</a>
    </section>
  </article>
</BaseLayout>
