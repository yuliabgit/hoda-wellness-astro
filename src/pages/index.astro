---
import BaseLayout from '../layouts/BaseLayout.astro';
import TeamMemberImage from '../components/TeamMemberImage.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import team from '../data/team.ts';
import { SITE_CITY } from '../utils/seo';

const founder = team.find((m) => m.founder);
const rest = team.filter((m) => m !== founder);
const previewMembers = founder ? [founder, ...rest] : team;

const title = `HODA Wellness Group | Integrated Wellness in ${SITE_CITY}`;
const description =
  'Personalized, evidence-informed wellness programs integrating metabolic health, nutrition, physical resilience, and nervous system regulation for durable aging.';
---

<BaseLayout
  title={title}
  description={description}
  ogImage="/images/hero.jpg"
  activeNav="home"
  transparentHeader={true}
>
  <section class="hero" aria-label="Hero">
    <div class="hero__bg hero__bg--photo" role="img" aria-label="Woman hiking mountain trail at golden hour">
      <OptimizedImage
        src="/images/hero.jpg"
        alt=""
        width={1920}
        height={1080}
        loading="eager"
        fetchpriority="high"
        quality={55}
      />
    </div>
    <div class="hero__inner">
      <div class="hero__content">
        <span class="eyebrow">HODA Wellness Group</span>
        <h1>Health Optimization for Durable Aging</h1>
        <p>
          Personalized, evidence-informed programs that integrate metabolic health,
          nutrition, physical resilience, and nervous system regulation—so you can
          live stronger, longer.
        </p>
        <div class="btn-row">
          <a class="btn btn--primary" href="/contact">Book Your Assessment</a>
          <a class="btn btn--outline" href="#approach">Learn Our Approach</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--bg">
    <div class="container">
      <div class="two-col">
        <div class="two-col__text">
          <span class="eyebrow">The Problem</span>
          <h2>Living longer doesn't always mean living better.</h2>
          <p>
            Chronic stress, metabolic dysfunction, inflammation, poor recovery, and
            hormonal changes can steal your energy, strength, and clarity.
          </p>
          <p class="bold">You deserve a different approach.</p>
        </div>
        <div class="two-col__media">
          <div class="ph ph--photo ph--aspect-4-3">
            <OptimizedImage
              src="/images/problem.jpg"
              alt="A reflective moment in nature"
              width={800}
              height={600}
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--bg-alt" id="approach">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Our Four Pillars</span>
        <h2>An Integrated Approach to Lasting Health</h2>
      </div>
      <div class="pillars">
        <article class="pillar-card">
          <div class="pillar-card__icon" aria-hidden="true">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M5 19c0-9 6-14 14-14 0 9-5 14-14 14z"></path><path
                d="M5 19c2-3 5-6 9-8"></path></svg
            >
          </div>
          <h3>Nutrition</h3>
          <p>
            Personalized nutrition strategies that reduce inflammation, support
            metabolism, and fuel your body.
          </p>
        </article>
        <article class="pillar-card">
          <div class="pillar-card__icon" aria-hidden="true">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><line x1="4" y1="20" x2="20" y2="20"></line><rect
                x="5"
                y="12"
                width="3"
                height="8"></rect><rect x="10.5" y="8" width="3" height="12"></rect><rect
                x="16"
                y="4"
                width="3"
                height="16"></rect></svg
            >
          </div>
          <h3>Metabolic Health</h3>
          <p>
            Advanced lab testing, CGM insights, and data-driven strategies to optimize
            metabolism and hormones.
          </p>
        </article>
        <article class="pillar-card">
          <div class="pillar-card__icon" aria-hidden="true">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><line x1="2" y1="12" x2="22" y2="12"></line><rect
                x="3"
                y="9"
                width="3"
                height="6"></rect><rect x="18" y="9" width="3" height="6"></rect><rect
                x="7"
                y="7"
                width="2.5"
                height="10"></rect><rect x="14.5" y="7" width="2.5" height="10"></rect></svg
            >
          </div>
          <h3>Physical Resilience</h3>
          <p>
            Strength, mobility, and conditioning programs designed to build lean muscle,
            improve function, and prevent injury.
          </p>
        </article>
        <article class="pillar-card">
          <div class="pillar-card__icon" aria-hidden="true">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M12 4c0 4 3 7 3 10a3 3 0 0 1-6 0c0-3 3-6 3-10z"></path><path
                d="M4 14c2 0 4 1 5 3"></path><path d="M20 14c-2 0-4 1-5 3"></path><line
                x1="6"
                y1="20"
                x2="18"
                y2="20"></line></svg
            >
          </div>
          <h3>Nervous System Regulation</h3>
          <p>
            Stress resilience, sleep optimization, HRV tracking, and recovery practices
            for a calm, strong nervous system.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--white">
    <div class="container">
      <div class="two-col">
        <div class="two-col__text">
          <span class="eyebrow">Our Program</span>
          <h2>A Personalized Path To Your Best Health</h2>
          <ul class="checklist">
            <li>
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.4"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg
              >
              <span>Comprehensive assessment &amp; lab review</span>
            </li>
            <li>
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.4"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg
              >
              <span>Wearable &amp; CGM integration</span>
            </li>
            <li>
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.4"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg
              >
              <span>Personalized plan &amp; expert coaching</span>
            </li>
            <li>
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.4"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg
              >
              <span>Ongoing support &amp; accountability</span>
            </li>
            <li>
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.4"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg
              >
              <span>Measurable progress &amp; sustainable results</span>
            </li>
          </ul>
          <div class="btn-row">
            <a class="btn btn--primary" href="/programs">Explore Our Programs</a>
          </div>
        </div>
        <div class="two-col__media">
          <div class="ph ph--photo ph--aspect-3-4">
            <OptimizedImage
              src="/images/program-teaser.jpg"
              alt="Personalized program in progress"
              width={600}
              height={800}
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--bg-alt">
    <div class="container">
      <div class="two-col">
        <div class="two-col__text">
          <span class="eyebrow">Why HODA</span>
          <h2>We look at the whole you.</h2>
          <p>
            We combine the best of modern science with a deep understanding of behavior
            change and human biology. Our integrated team works together to help you feel
            stronger, more energized, and more in control of your health—at every stage
            of life.
          </p>
          <p
            class="italic"
            style="display:flex;align-items:center;gap:8px;color:var(--color-accent);"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><path d="M5 19c0-9 6-14 14-14 0 9-5 14-14 14z"></path></svg
            >
            Evidence-informed. Personalized. Sustainable.
          </p>
        </div>
        <div class="two-col__media">
          <div class="ph ph--photo ph--aspect-4-3">
            <OptimizedImage
              src="/images/why-hoda.jpg"
              alt="The HODA approach — whole-person health"
              width={800}
              height={600}
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--white">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Meet Our Team</span>
        <h2>Experts Who Care</h2>
        <p>A collaborative team of specialists dedicated to your long-term health.</p>
      </div>
      <div class="team-grid team-grid--preview">
        {
          previewMembers.map((m) => (
            <a class="team-card team-card--link" href={`/team#${m.id}`}>
              <TeamMemberImage image={m.image} initials={m.initials} name={m.name} />
              <h4>{m.name}</h4>
              <p class="role">{m.title}</p>
            </a>
          ))
        }
      </div>
      <div class="center-text">
        <a class="team-link" href="/team">Meet the Full Team →</a>
      </div>
    </div>
  </section>

  <section class="section section--bg-alt">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">What Our Clients Say</span>
      </div>
      <div class="testimonials">
        <article class="testimonial-card">
          <p>
            HODA Wellness Group helped me get my energy, focus, and strength back. I
            finally feel like myself again!
          </p>
          <div class="attr">— Sarah T., 45</div>
        </article>
        <article class="testimonial-card">
          <p>
            The integrated approach is unlike anything I've tried. The data, coaching, and
            support made all the difference.
          </p>
          <div class="attr">— Mark L., 52</div>
        </article>
        <article class="testimonial-card">
          <p>
            I sleep better, handle stress better, and have more vitality than I have in
            years. Highly recommend!
          </p>
          <div class="attr">— Jennifer R., 48</div>
        </article>
      </div>
    </div>
  </section>

  <section class="cta-banner">
    <h2>Ready to Take the Next Step?</h2>
    <p>Your best health is within reach. Let's build your personalized plan.</p>
    <a class="btn btn--warm" href="/contact">Contact Us</a>
  </section>
</BaseLayout>
